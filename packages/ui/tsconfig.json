{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "jsx": "preserve",
    "types": ["react", "react-dom"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"]
}

// Librería de componentes UI para el monorepo
// Estrategia: componentes "agnósticos" (como una librería)
// - jsx: "preserve" → no transforma JSX, el bundler del consumidor lo hace
// - moduleResolution: "Bundler" → funciona con Vite/esbuild
// - Sin strict ni paths porque es autocontenido (no consume otros paquetes)
